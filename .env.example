LIFE_OS_TIMEZONE=America/Toronto
# deterministic | auto | llm
LIFE_OS_EXTRACTOR=auto
LIFE_OS_LLM_TIMEOUT_SECONDS=60

# OpenRouter is used only when LIFE_OS_EXTRACTOR is auto or llm.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_FALLBACK_MODELS=nvidia/nemotron-3-nano-30b-a3b:free

# Telegram.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BRIEFING_CHAT_ID=
TELEGRAM_SEND_CONFIRMATIONS=true
TELEGRAM_ENABLE_VOICE_NOTES=true
# faster-whisper runs locally. First use downloads the selected model.
TELEGRAM_VOICE_TRANSCRIPTION_BACKEND=faster-whisper
TELEGRAM_VOICE_TRANSCRIPTION_MODEL=base
TELEGRAM_VOICE_TRANSCRIPTION_DEVICE=cpu
TELEGRAM_VOICE_TRANSCRIPTION_COMPUTE_TYPE=int8
TELEGRAM_VOICE_MAX_BYTES=20971520
# Optional API-compatible transcription backend instead of local faster-whisper.
TELEGRAM_VOICE_TRANSCRIPTION_API_KEY=
TELEGRAM_VOICE_TRANSCRIPTION_BASE_URL=https://api.openai.com/v1
BRIEFING_CRON_SECRET=

# ngrok free tunnel for local Telegram webhook testing.
NGROK_AUTHTOKEN=

# Optional remote SQLite-compatible persistence for free cloud deploys.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
TURSO_REPLICA_PATH=/tmp/life-os-turso-replica.sqlite3
TURSO_SYNC_INTERVAL_SECONDS=60
