# deterministic | auto | llm
LIFE_OS_EXTRACTOR=auto
LIFE_OS_TIMEZONE=America/Toronto

# OpenRouter is used only when LIFE_OS_EXTRACTOR is auto or llm.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_FALLBACK_MODELS=nvidia/nemotron-3-nano-30b-a3b:free

# Telegram phase 3.
# Create a bot with BotFather and place the token here locally only.
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram numeric user IDs allowed to log data.
TELEGRAM_ALLOWED_USER_IDS=

# Optional secret sent by Telegram in X-Telegram-Bot-Api-Secret-Token.
TELEGRAM_WEBHOOK_SECRET=

# Keep true for normal use. Set false during local webhook testing.
TELEGRAM_SEND_CONFIRMATIONS=true

# ngrok free tunnel for Telegram webhooks.
NGROK_AUTHTOKEN=

# Optional overrides.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LIFE_OS_LLM_TIMEOUT_SECONDS=30
